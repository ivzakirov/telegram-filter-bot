# Get from https://my.telegram.org → API development tools
API_ID=12345
API_HASH=your_api_hash_here

# Generate with: python gen_session.py
SESSION_STRING=

# Path to the SQLite database file (optional, default: filters.db)
# Output chats are configured per-pipeline via the .add_pipeline command
# DB_PATH=filters.db

# Trusted accounts: can manage the bot via direct messages
# Comma-separated numeric user_ids (find yours with @userinfobot)
# TRUSTED_USERS=123456789,987654321
