# Получить на https://my.telegram.org → API development tools
API_ID=12345
API_HASH=your_api_hash_here

# Сгенерировать командой: python gen_session.py
SESSION_STRING=

# ID чата куда пересылать совпадения (приватный канал или группа).
# Чтобы узнать ID: создайте группу/канал, добавьте бота @userinfobot
# или отправьте туда сообщение и посмотрите chat_id через Pyrogram.
# Для приватных каналов ID начинается с -100.
OUTPUT_CHAT=-1001234567890

# Путь к файлу базы данных (необязательно, по умолчанию filters.db)
# DB_PATH=filters.db
